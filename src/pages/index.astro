---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/global.css';
import { Hero } from '@/components/sections/Hero';
import { AudienceModeSwitch } from '@/components/sections/AudienceModeSwitch';
import { OfferDeliverables } from '@/components/sections/OfferDeliverables';
import { CaseProofs } from '@/components/sections/CaseProofs';
import { GraphicSprints } from '@/components/sections/GraphicSprints';
import { MissionConfigurator } from '@/components/sections/MissionConfigurator';
import { About } from '@/components/sections/About';
import { ProcessStateMachine } from '@/components/sections/ProcessStateMachine';
import { LabNotes } from '@/components/sections/LabNotes';
import { Contact } from '@/components/sections/Contact';
import { TRACK_EVENTS, trackAttrs } from '@/lib/tracking';
---

<BaseLayout>
  <header class="sticky top-0 z-30 site-nav">
    <div class="site-shell figma-lab-nav-row">
      <a href="#top" class="figma-lab-nav-title">ELECTRONICS MISSION STUDIO</a>
      <nav aria-label="Navigation principale">
        <ul class="figma-lab-nav-list">
          <li><a href="#a-propos" class="figma-lab-nav-link site-navlink">#a-propos</a></li>
          <li><a href="#lab-notes" class="figma-lab-nav-link site-navlink">#preuves</a></li>
          <li><a href="#contact" class="figma-lab-nav-link site-navlink">#contact</a></li>
        </ul>
      </nav>
      <button class="site-contrast-toggle" data-theme-toggle type="button" aria-pressed="false">
        Mode contraste
      </button>
    </div>
  </header>

  <main class="site-shell studio-structure pb-12 pt-3">
    <section class="structure-grid structure-grid--hero" data-reveal>
      <div class="structure-cell structure-cell--hero">
        <Hero client:load />
      </div>
    </section>

    <section class="structure-grid structure-grid--audience" data-reveal>
      <div class="structure-cell structure-cell--audience">
        <AudienceModeSwitch client:visible />
      </div>
    </section>

    <section class="structure-grid structure-grid--offer" data-reveal>
      <div class="structure-cell structure-cell--offer">
        <OfferDeliverables client:visible />
      </div>
    </section>

    <section class="structure-grid structure-grid--method" data-reveal>
      <div class="structure-cell structure-cell--process">
        <ProcessStateMachine client:visible />
      </div>
    </section>

    <section class="structure-grid structure-grid--cases" data-reveal>
      <div class="structure-cell structure-cell--cases">
        <CaseProofs client:visible />
      </div>
    </section>

    <section class="structure-grid structure-grid--proofs" data-reveal>
      <div class="structure-cell structure-cell--notes">
        <LabNotes client:visible />
      </div>
    </section>

    <section class="structure-grid structure-grid--about" data-reveal>
      <div class="structure-cell structure-cell--about">
        <About client:visible />
      </div>
    </section>

    <section class="structure-grid structure-grid--config" data-reveal>
      <div class="structure-cell structure-cell--config">
        <MissionConfigurator client:visible />
      </div>
    </section>

    <section class="structure-grid structure-grid--conversion" data-reveal>
      <div class="structure-cell structure-cell--contact">
        <Contact client:visible />
      </div>
    </section>

    <section class="structure-grid structure-grid--journal" data-reveal>
      <div class="structure-cell structure-cell--sprints">
        <GraphicSprints client:visible />
      </div>
    </section>
  </main>

  <footer class="site-footer border-t border-[var(--line)] py-6 text-sm text-[var(--text-muted)]">
    <div class="site-shell footer-grid">
      <div class="footer-col footer-col--brand">
        <p class="m-0 footer-title">L'electron rare</p>
        <p class="mb-0 mt-1 footer-copy">
          © 2026 Clement Saillant - studio premium de conception electronique, architecture systeme et delivery sur mesure.
        </p>
        <p class="mb-0 mt-2 footer-copy">
          Positionnement: execution technique exigeante, pilotage agile et accompagnement mission pour decideurs produit.
        </p>
      </div>
      <div class="footer-col footer-col--protocols">
        <p class="m-0 footer-column-title">Protocoles actifs</p>
        <ul class="footer-protocol-list">
          <li><a href="#lab-notes" class="footer-link">Preuves</a></li>
          <li><a href="#a-propos" class="footer-link">A propos</a></li>
          <li><a href="#sprints-graphiques" class="footer-link">Journal</a></li>
          <li><a href="#contact" class="footer-link">Mission</a></li>
        </ul>
      </div>
      <nav aria-label="Ressources studio" class="footer-links">
        <a
          href="https://fr.linkedin.com/in/electron-rare"
          target="_blank"
          rel="noopener noreferrer"
          {...trackAttrs(TRACK_EVENTS.outboundLinkedinContact, 'linkedin.com')}
          class="footer-link"
        >
          LinkedIn
        </a>
      </nav>
    </div>
  </footer>
</BaseLayout>

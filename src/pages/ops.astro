---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/global.css';
---

<BaseLayout title="Ops — L'Electron Rare" description="Centre opérationnel avec IA mascarade.">
  <main class="ops" id="ops-main">

    <!-- Header -->
    <div class="ops-header">
      <div>
        <h1 class="ops-title">Ops <span class="electric">L'Electron Rare</span></h1>
        <p class="ops-sub">Centre opérationnel · IA mascarade intégrée</p>
      </div>
      <div class="status-bar" id="status-bar">
        <span class="status-dot" id="status-dot"></span>
        <span class="status-text" id="status-text">Connexion...</span>
      </div>
    </div>

    <!-- Tabs -->
    <nav class="tabs" id="tabs">
      <button class="tab tab--active" data-tab="workflow">Workflow</button>
      <button class="tab" data-tab="business">Business Plan</button>
      <button class="tab" data-tab="marketing">Marketing</button>
      <button class="tab" data-tab="copilot">Copilote IA</button>
      <button class="tab" data-tab="crm">CRM Live</button>
      <button class="tab" data-tab="agents">Agents</button>
      <button class="tab" data-tab="monitor">Monitoring</button>
    </nav>

    <!-- TAB: Workflow -->
    <section class="panel panel--active" id="panel-workflow">

      <div class="workflow-header">
        <h2 class="section-title">Actions en cours</h2>
        <div class="workflow-stats" id="workflow-stats"></div>
      </div>

      <!-- Urgents -->
      <div class="task-group">
        <h3 class="group-label group-label--red">Urgent — Deadline proche</h3>
        <div class="task-list" id="urgent-tasks">
          <div class="task task--urgent" data-due="2026-03-31" data-id="fat">
            <div class="task-header">
              <input type="checkbox" class="task-check" id="task-fat" />
              <label for="task-fat" class="task-label">Formaliser accord FAT</label>
              <span class="task-badge badge--red">31 mars</span>
              <button class="task-ai-btn" data-agent="writer" data-prompt="Rédige un contrat de partenariat formation entre L'Electron Rare (Clément Saillant, ingénieur électronique freelance Marseille) et Funky Audio Tools pour des formations en électronique embarquée. Inclus: split marge 70/30, responsabilités, assurance RC pro, durée 1 an renouvelable." title="Générer avec IA">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </button>
            </div>
            <div class="task-body">
              <p>Rédiger contrat partenariat formation avec Funky Audio Tools.</p>
              <div class="ai-output" id="ai-output-fat"></div>
              <div class="task-actions">
                <a href="mailto:?subject=Accord%20partenariat%20formation%20FAT" class="btn btn--outline">Rédiger email</a>
                <a href="https://tower.saillant.cc/app/crm" target="_blank" class="btn btn--outline">CRM</a>
              </div>
            </div>
          </div>

          <div class="task task--urgent" data-due="2026-03-31" data-id="gie">
            <div class="task-header">
              <input type="checkbox" class="task-check" id="task-gie" />
              <label for="task-gie" class="task-label">One-pager GIE Hémisphère</label>
              <span class="task-badge badge--red">31 mars</span>
              <button class="task-ai-btn" data-agent="writer" data-prompt="Rédige un one-pager professionnel pour un GIE entre L'Electron Rare (électronique embarquée) et Hémisphère (multi-technique). Offre: systèmes électroniques spécifiques pour l'industrie et la culture. Format: titre, proposition de valeur, compétences croisées, références, contact." title="Générer avec IA">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </button>
            </div>
            <div class="task-body">
              <p>Compléter le one-pager collectif avec Hémisphère.</p>
              <div class="ai-output" id="ai-output-gie"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Prospection -->
      <div class="task-group">
        <h3 class="group-label group-label--amber">Prospection</h3>
        <div class="task-list">
          <div class="task" data-due="2026-03-25" data-id="mediatone">
            <div class="task-header">
              <input type="checkbox" class="task-check" id="task-mediatone" />
              <label for="task-mediatone" class="task-label">Email Mediatone — Sarah Le Tolguenec</label>
              <span class="task-badge badge--amber">Prospection</span>
              <button class="task-ai-btn" data-agent="writer" data-prompt="Rédige un email de proposition de formation 'Dispositifs Culturels' (1 jour, 775€ HT, LED/DMX/intégration technique) à Sarah Le Tolguenec, coordinatrice formation chez Mediatone (association culturelle Lyon, certifiée Qualiopi). Ton professionnel, concis." title="Générer avec IA">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </button>
            </div>
            <div class="task-body">
              <p>Proposition formation Dispositifs Culturels. Portes ouvertes 31 mars.</p>
              <div class="ai-output" id="ai-output-mediatone"></div>
              <div class="task-actions">
                <a href="mailto:site@mediatone.net?subject=Proposition%20formation%20%E2%80%94%20%C3%89lectronique%20spectacle" class="btn btn--primary">Envoyer email</a>
                <a href="https://tower.saillant.cc/app/crm/CRM-LEAD-2026-00027" target="_blank" class="btn btn--outline">Fiche CRM</a>
              </div>
            </div>
          </div>

          <div class="task" data-id="prospect-debug">
            <div class="task-header">
              <input type="checkbox" class="task-check" id="task-prospect-debug" />
              <label for="task-prospect-debug" class="task-label">5 emails prospection Debug & Mesure</label>
              <span class="task-badge badge--cyan">Formation</span>
              <button class="task-ai-btn" data-agent="writer" data-prompt="Génère 5 variantes personnalisées d'un email de prospection pour la formation 'Debug & Mesure' (1 jour, 775€, oscilloscope/analyseur logique/méthodologie). Cibles: PME tech, labos R&D, écoles d'ingénieurs. Pour chaque variante: nom entreprise fictif, prénom contact, angle personnalisé." title="Générer 5 variantes">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </button>
            </div>
            <div class="task-body">
              <div class="ai-output" id="ai-output-prospect-debug"></div>
              <div class="task-actions">
                <a href="https://tower.saillant.cc/app/crm" target="_blank" class="btn btn--outline">Choisir cibles CRM</a>
              </div>
            </div>
          </div>

          <div class="task" data-id="cibles-gie">
            <div class="task-header">
              <input type="checkbox" class="task-check" id="task-cibles-gie" />
              <label for="task-cibles-gie" class="task-label">Lister 20 cibles hybrides GIE</label>
              <span class="task-badge badge--amber">30 avril</span>
            </div>
          </div>
        </div>
      </div>

      <!-- LinkedIn -->
      <div class="task-group">
        <h3 class="group-label group-label--blue">LinkedIn — Planning éditorial</h3>
        <div class="task-list" id="linkedin-tasks"></div>
      </div>

      <!-- Technique restant -->
      <div class="task-group">
        <h3 class="group-label group-label--cyan">Technique restant</h3>
        <div class="task-list">
          <div class="task" data-id="gsc"><div class="task-header"><input type="checkbox" class="task-check" id="task-gsc" /><label for="task-gsc" class="task-label">Google Search Console — ajouter lelectronrare.fr</label><span class="task-badge badge--cyan">SEO</span></div><div class="task-body"><p>Se connecter à <a href="https://search.google.com/search-console" target="_blank">Google Search Console</a>, ajouter www.lelectronrare.fr, copier le code TXT de vérification.</p></div></div>
          <div class="task" data-id="calcom-setup"><div class="task-header"><input type="checkbox" class="task-check" id="task-calcom" /><label for="task-calcom" class="task-label">Configurer dispo Cal.com (horaires, jours)</label><span class="task-badge badge--cyan">Config</span></div><div class="task-body"><div class="task-actions"><a href="https://rdv.saillant.cc/settings/my-account/availability" target="_blank" class="btn btn--outline">Cal.com Availability</a></div></div></div>
          <div class="task" data-id="metabase-dash"><div class="task-header"><input type="checkbox" class="task-check" id="task-metabase" /><label for="task-metabase" class="task-label">Personnaliser dashboard Metabase</label><span class="task-badge badge--cyan">KPI</span></div><div class="task-body"><div class="task-actions"><a href="https://kpi.saillant.cc/dashboard/2" target="_blank" class="btn btn--outline">Dashboard Pipeline</a></div></div></div>
        </div>
      </div>

      <!-- Lancement -->
      <div class="task-group">
        <h3 class="group-label group-label--green">Lancement — 1er mai</h3>
        <div class="task-list">
          <div class="task" data-id="launch"><div class="task-header"><input type="checkbox" class="task-check" id="task-launch" /><label for="task-launch" class="task-label">Swap countdown → site complet</label><span class="task-badge badge--green">1er mai</span></div><div class="task-body"><pre class="code-block">bash ~/lib/launch-site.sh</pre><p>Rollback si problème :</p><pre class="code-block">bash ~/lib/rollback-site.sh</pre></div></div>
          <div class="task" data-id="newsletter-launch"><div class="task-header"><input type="checkbox" class="task-check" id="task-nl" /><label for="task-nl" class="task-label">Newsletter "Lancement" (template ID 10)</label><span class="task-badge badge--green">1er mai</span></div><div class="task-body"><div class="task-actions"><a href="https://mail.saillant.cc" target="_blank" class="btn btn--primary">Listmonk</a></div></div></div>
          <div class="task" data-id="li6"><div class="task-header"><input type="checkbox" class="task-check" id="task-li6" /><label for="task-li6" class="task-label">LinkedIn #06 — "C'est en ligne"</label><span class="task-badge badge--green">1er mai</span></div></div>
          <div class="task" data-id="deploy-final"><div class="task-header"><input type="checkbox" class="task-check" id="task-deploy" /><label for="task-deploy" class="task-label">Deploy final + vérification toutes pages</label><span class="task-badge badge--green">1er mai</span></div><div class="task-body"><pre class="code-block">bash ~/lib/deploy-site.sh</pre></div></div>
        </div>
      </div>

      <!-- Complété session 20 mars -->
      <div class="task-group">
        <h3 class="group-label" style="color:var(--text-dim);border-bottom-color:var(--line-soft)">Complété — 20 mars</h3>
        <div class="task-list">
          <div class="task task--done" data-id="d-brevo"><div class="task-header"><input type="checkbox" class="task-check" id="task-d-brevo" checked disabled /><label class="task-label">SMTP Brevo + DKIM/SPF configurés</label></div></div>
          <div class="task task--done" data-id="d-dns"><div class="task-header"><input type="checkbox" class="task-check" id="task-d-dns" checked disabled /><label class="task-label">DNS lelectronrare.fr migré Cloudflare</label></div></div>
          <div class="task task--done" data-id="d-site"><div class="task-header"><input type="checkbox" class="task-check" id="task-d-site" checked disabled /><label class="task-label">Site déployé via tunnel Cloudflare</label></div></div>
          <div class="task task--done" data-id="d-api"><div class="task-header"><input type="checkbox" class="task-check" id="task-d-api" checked disabled /><label class="task-label">API CRM + AI scoring Ollama</label></div></div>
          <div class="task task--done" data-id="d-welcome"><div class="task-header"><input type="checkbox" class="task-check" id="task-d-welcome" checked disabled /><label class="task-label">Welcome sequence 3 emails Listmonk</label></div></div>
          <div class="task task--done" data-id="d-lms"><div class="task-header"><input type="checkbox" class="task-check" id="task-d-lms" checked disabled /><label class="task-label">Frappe LMS 3 cours + 13 chapitres</label></div></div>
          <div class="task task--done" data-id="d-calcom"><div class="task-header"><input type="checkbox" class="task-check" id="task-d-calcom" checked disabled /><label class="task-label">Cal.com 4 créneaux + CalDAV Apple</label></div></div>
          <div class="task task--done" data-id="d-metabase"><div class="task-header"><input type="checkbox" class="task-check" id="task-d-metabase" checked disabled /><label class="task-label">Metabase dashboards + DB Frappe</label></div></div>
          <div class="task task--done" data-id="d-n8n"><div class="task-header"><input type="checkbox" class="task-check" id="task-d-n8n" checked disabled /><label class="task-label">n8n workflows + route Traefik</label></div></div>
          <div class="task task--done" data-id="d-infra"><div class="task-header"><input type="checkbox" class="task-check" id="task-d-infra" checked disabled /><label class="task-label">Docker pinning + backup MariaDB + Redis AOF</label></div></div>
          <div class="task task--done" data-id="d-auth"><div class="task-header"><input type="checkbox" class="task-check" id="task-d-auth" checked disabled /><label class="task-label">Authentik SSO sur /ops /intranet (Cloudflare Access supprimé)</label></div></div>
          <div class="task task--done" data-id="d-portfolio"><div class="task-header"><input type="checkbox" class="task-check" id="task-d-portfolio" checked disabled /><label class="task-label">Portfolio KiCanvas KXKM ESP32 + Parallelator</label></div></div>
          <div class="task task--done" data-id="d-robots"><div class="task-header"><input type="checkbox" class="task-check" id="task-d-robots" checked disabled /><label class="task-label">robots.txt noindex pages internes</label></div></div>
          <div class="task task--done" data-id="d-scripts"><div class="task-header"><input type="checkbox" class="task-check" id="task-d-scripts" checked disabled /><label class="task-label">Scripts deploy-site.sh + launch-site.sh + rollback-site.sh</label></div></div>
          <div class="task task--done" data-id="d-crm-fr"><div class="task-header"><input type="checkbox" class="task-check" id="task-d-crm-fr" checked disabled /><label class="task-label">CRM Frappe en français + 50 rôles Clément</label></div></div>
        </div>
      </div>
    </section>

    <!-- TAB: Business Plan -->
    <section class="panel" id="panel-business">
      <h2 class="section-title">Business Plan — Backlog maître</h2>
      <p class="hint">Source de vérité : <a href="https://github.com/electron-rare/communication-marketing-electron-rare" target="_blank" class="portfolio-link">Business OS</a></p>

      <div class="task-group">
        <h3 class="group-label group-label--green">P0 — Clarté commerciale (DONE)</h3>
        <div class="task-list">
          <div class="task task--done"><div class="task-header"><input type="checkbox" checked disabled class="task-check" /><label class="task-label">Positionnement "systèmes électroniques spécifiques"</label></div></div>
          <div class="task task--done"><div class="task-header"><input type="checkbox" checked disabled class="task-check" /><label class="task-label">Grille prix simple et assumée</label></div></div>
          <div class="task task--done"><div class="task-header"><input type="checkbox" checked disabled class="task-check" /><label class="task-label">Messages alignés site/SEO/LinkedIn</label></div></div>
        </div>
      </div>

      <div class="task-group">
        <h3 class="group-label group-label--green">P1 — Preuves (DONE)</h3>
        <div class="task-list">
          <div class="task task--done"><div class="task-header"><input type="checkbox" checked disabled class="task-check" /><label class="task-label">Cas industrie + culture + formation écrits</label></div></div>
          <div class="task task--done"><div class="task-header"><input type="checkbox" checked disabled class="task-check" /><label class="task-label">3 preuves courtes LinkedIn/homepage</label></div></div>
        </div>
      </div>

      <div class="task-group">
        <h3 class="group-label group-label--amber">P2 — Formation</h3>
        <div class="task-list">
          <div class="task task--done"><div class="task-header"><input type="checkbox" checked disabled class="task-check" /><label class="task-label">3 modules vendables (KiCad 2j/1550€, Debug 1j/775€, Dispositifs 1j/775€)</label></div></div>
          <div class="task task--done"><div class="task-header"><input type="checkbox" checked disabled class="task-check" /><label class="task-label">Process FAT, trames proposition, matrices marge</label></div></div>
          <div class="task task--done"><div class="task-header"><input type="checkbox" checked disabled class="task-check" /><label class="task-label">One-pagers commerciaux + templates email prospection</label></div></div>
          <div class="task" data-id="bp-fat"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-fat" /><label for="task-bp-fat" class="task-label">Formaliser accord FAT (contrat, split, assurance)</label><span class="task-badge badge--red">31 mars</span></div></div>
          <div class="task" data-id="bp-prospects"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-prospects" /><label for="task-bp-prospects" class="task-label">Lister 20-30 prospects qualifiés</label></div></div>
          <div class="task" data-id="bp-test-vente"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-test" /><label for="task-bp-test" class="task-label">Tester 2 ventes/sessions (Debug & Mesure recommandé en premier)</label></div></div>
          <div class="task" data-id="bp-marge"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-marge" /><label for="task-bp-marge" class="task-label">Mesurer marge / charge / satisfaction sur réel</label></div></div>
        </div>
      </div>

      <div class="task-group">
        <h3 class="group-label group-label--amber">P3 — GIE Hémisphère</h3>
        <div class="task-list">
          <div class="task task--done"><div class="task-header"><input type="checkbox" checked disabled class="task-check" /><label class="task-label">Objet, règles leads/coûts, one-pager (trame)</label></div></div>
          <div class="task" data-id="bp-onepager"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-onepager" /><label for="task-bp-onepager" class="task-label">Finaliser one-pager avec Hémisphère</label><span class="task-badge badge--red">31 mars</span></div></div>
          <div class="task" data-id="bp-cibles20"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-cibles20" /><label for="task-bp-cibles20" class="task-label">20 cibles hybrides locales</label><span class="task-badge badge--amber">30 avril</span></div></div>
          <div class="task" data-id="bp-visites"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-visites" /><label for="task-bp-visites" class="task-label">6 visites/rencontres + 1 offre hybride</label><span class="task-badge badge--amber">31 mai</span></div></div>
        </div>
      </div>

      <div class="task-group">
        <h3 class="group-label group-label--cyan">P4 — CRM & Pilotage</h3>
        <div class="task-list">
          <div class="task task--done"><div class="task-header"><input type="checkbox" checked disabled class="task-check" /><label class="task-label">CRM Frappe live + formulaire site → lead + AI scoring</label></div></div>
          <div class="task" data-id="bp-suivi-sources"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-sources" /><label for="task-bp-sources" class="task-label">Suivre leads par source (site, LinkedIn, partenaires)</label></div><div class="task-body"><div class="task-actions"><a href="https://kpi.saillant.cc/dashboard/2" target="_blank" class="btn btn--outline">Dashboard Metabase</a></div></div></div>
          <div class="task" data-id="bp-revue"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-revue" /><label for="task-bp-revue" class="task-label">Revue mensuelle pipeline</label><span class="task-badge badge--cyan">Mensuel</span></div></div>
        </div>
      </div>

      <div class="task-group">
        <h3 class="group-label group-label--cyan">P5 — Migration Frappe</h3>
        <div class="task-list">
          <div class="task task--done"><div class="task-header"><input type="checkbox" checked disabled class="task-check" /><label class="task-label">Frappe CRM + ERPNext + LMS bootstrappé sur Tower</label></div></div>
          <div class="task" data-id="bp-import-leads"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-import" /><label for="task-bp-import" class="task-label">Importer leads historiques (0 réels dans legacy)</label></div></div>
          <div class="task" data-id="bp-devis"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-devis" /><label for="task-bp-devis" class="task-label">Basculer devis/facturation vers ERPNext</label></div></div>
          <div class="task" data-id="bp-readonly"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-readonly" /><label for="task-bp-readonly" class="task-label">CRM custom en read-only</label></div></div>
        </div>
      </div>

      <div class="task-group">
        <h3 class="group-label group-label--blue">P7 — Exécution commerciale</h3>
        <div class="task-list">
          <div class="task" data-id="bp-li5"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-li5" /><label for="task-bp-li5" class="task-label">Publier 5 posts LinkedIn (S12-S16)</label><span class="task-badge badge--blue">Avril</span></div></div>
          <div class="task" data-id="bp-email15"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-email15" /><label for="task-bp-email15" class="task-label">Envoyer 15 emails prospection Debug & Mesure</label></div></div>
          <div class="task" data-id="bp-ecole"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-ecole" /><label for="task-bp-ecole" class="task-label">Relancer école art numérique (reconduction KiCad)</label></div></div>
          <div class="task" data-id="bp-culture3"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-culture3" /><label for="task-bp-culture3" class="task-label">Contacter 3 compagnies culture (Dispositifs Culturels)</label></div></div>
          <div class="task" data-id="bp-appels3"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-appels3" /><label for="task-bp-appels3" class="task-label">Réaliser 3 appels découverte</label></div></div>
          <div class="task" data-id="bp-prop2"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-prop2" /><label for="task-bp-prop2" class="task-label">Envoyer 2 propositions formation</label></div></div>
          <div class="task" data-id="bp-session1"><div class="task-header"><input type="checkbox" class="task-check" id="task-bp-session1" /><label for="task-bp-session1" class="task-label">Planifier 1 session formation avant fin avril</label></div></div>
        </div>
      </div>

      <div class="task-group">
        <h3 class="group-label">P6 — Outils marketing</h3>
        <div class="task-list">
          <div class="task task--done"><div class="task-header"><input type="checkbox" checked disabled class="task-check" /><label class="task-label">Listmonk, SMTP Brevo, welcome sequence, Cal.com, Metabase, LMS</label></div></div>

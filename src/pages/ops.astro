  .tab:hover { color:var(--text,#f4eee3); }
  .tab--active { color:var(--electric,#5bd1d8); border-bottom-color:var(--electric,#5bd1d8); }

  .panel { display:none; }
  .panel--active { display:block; }

  .section-title { font-family:'Fraunces',serif; font-size:20px; color:var(--accent,#f1c27a); margin:0 0 16px; }
  .subsection-title { font-family:'IBM Plex Mono',monospace; font-size:14px; color:var(--text-muted,#d6cbb9); margin:24px 0 12px; }

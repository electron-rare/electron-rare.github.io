        <div class="task-body">
          <pre class="template-block">${p.text}</pre>
          <div class="task-actions">
            <button class="btn btn--primary copy-btn" data-text="${encodeURIComponent(p.text)}">Copier</button>
            <a href="https://www.linkedin.com/feed/" target="_blank" class="btn btn--outline">LinkedIn</a>
            <button class="task-ai-btn-inline" data-agent="writer" data-prompt="Améliore ce post LinkedIn pour un ingénieur électronique freelance. Garde le ton technique et direct. Pas d'emoji abusif. Post original: ${encodeURIComponent(p.text)}">Améliorer avec IA</button>
          </div>
          <div class="ai-output" id="ai-output-${p.id}"></div>
        </div>
      </div>`;
  });

  // Re-bind events for generated tasks
  liContainer.querySelectorAll('.task-check').forEach(cb => {
    const key = 'ops-' + cb.id;
    cb.checked = localStorage.getItem(key) === '1';
    if (cb.checked) cb.closest('.task')?.classList.add('task--done');
